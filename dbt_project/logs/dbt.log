[0m21:54:44.698380 [debug] [Thread-4 (]: On model.olist_analytics.int_order_items_enriched: /* {"app": "dbt", "dbt_version": "1.8.3", "profile_name": "olist_analytics", "target_name": "dev", "node_id": "model.olist_analytics.int_order_items_enriched"} */

  create view "postgres"."intermediate"."int_order_items_enriched__dbt_tmp"
    
    
  as (
    with order_items as (
    select * from "postgres"."staging"."stg_order_items"
),

products as (
    select * from "postgres"."staging"."stg_products"
),

translations as (
    select * from "postgres"."staging"."stg_product_category_translation"
),

sellers as (
    select * from "postgres"."staging"."stg_sellers"
),

enriched as (
    select
        oi.order_id,
        oi.item_number,
        oi.product_id,
        oi.seller_id,
        coalesce(t.category_name_english, p.category_name, 'unknown') as category,
        p.weight_g,
        oi.price,
        oi.freight_value,
        oi.total_value,
        oi.shipping_limit_at,
        s.city   as seller_city,
        s.state  as seller_state
    from order_items oi
    left join products p     using (product_id)
    left join translations t on p.category_name = t.product_category_name
    left join sellers s      using (seller_id)
)

select * from enriched
  );
[0m21:54:44.699154 [debug] [Thread-2 (]: On model.olist_analytics.int_orders_enriched: /* {"app": "dbt", "dbt_version": "1.8.3", "profile_name": "olist_analytics", "target_name": "dev", "node_id": "model.olist_analytics.int_orders_enriched"} */

  create view "postgres"."intermediate"."int_orders_enriched__dbt_tmp"
    
    
  as (
    with orders as (
    select * from "postgres"."staging"."stg_orders"
),

customers as (
    select * from "postgres"."staging"."stg_customers"
),

payments as (
    select
        order_id,
        sum(payment_value)                              as total_payment,
        count(distinct payment_sequential)              as payment_count,
        max(installments)                               as max_installments,
        mode() within group (order by payment_type)    as main_payment_type
    from "postgres"."staging"."stg_order_payments"
    group by order_id
),

reviews as (
    select
        order_id,
        avg(review_score) as avg_review_score
    from "postgres"."staging"."stg_order_reviews"
    group by order_id
),

enriched as (
    select
        o.order_id,
        o.customer_id,
        c.customer_unique_id,
        c.city       as customer_city,
        c.state      as customer_state,
        o.order_status,
        o.purchased_at,
        o.approved_at,
        o.delivered_customer_at,
        o.estimated_delivery_at,
        o.delivery_time,
        p.total_payment,
        p.payment_count,
        p.max_installments,
        p.main_payment_type,
        r.avg_review_score,
        date_trunc('month', o.purchased_at) as purchase_month,
        date_trunc('week', o.purchased_at)  as purchase_week
    from orders o
    left join customers c using (customer_id)
    left join payments p  using (order_id)
    left join reviews r   using (order_id)
)

select * from enriched
  );
