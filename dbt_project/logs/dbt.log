  create  table "postgres"."marts"."mart_sales_by_category__dbt_tmp"
  
  
    as
  
  (
    with orders as (
    select * from "postgres"."intermediate"."int_orders_enriched"
),

items as (
    select * from "postgres"."intermediate"."int_order_items_enriched"
),

final as (
    select
        o.purchase_month,
        i.category,
        count(distinct o.order_id)       as total_orders,
        count(distinct o.customer_id)    as total_customers,
        sum(i.total_value)               as gmv,
        avg(i.price)                     as avg_price,
        avg(o.avg_review_score)          as avg_review_score,
        avg(extract(epoch from o.delivery_time) / 86400) as avg_delivery_days
    from orders o
    join items i using (order_id)
    where o.order_status = 'delivered'
    group by 1, 2
)

select * from final
  );
  
